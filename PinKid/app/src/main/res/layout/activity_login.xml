<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F7FCF9"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="40dp">

        <!-- 헤더 -->
        <TextView
            android:id="@+id/txtPinKid"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PinKid"
            android:textSize="32sp"
            android:textStyle="bold"
            android:textColor="#2D7A4F"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="80dp"/>

        <TextView
            android:id="@+id/txtSubTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="우리 아이가 있는 곳, 언제나 함께"
            android:textSize="14sp"
            android:textColor="#5AAB78"
            app:layout_constraintTop_toBottomOf="@id/txtPinKid"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="8dp"/>

        <View
            android:id="@+id/divider"
            android:layout_width="48dp"
            android:layout_height="4dp"
            android:background="#66B375"
            app:layout_constraintTop_toBottomOf="@id/txtSubTitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="20dp"/>

        <!-- 이메일 -->
        <TextView
            android:id="@+id/txtID"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="이메일"
            android:textSize="12sp"
            android:textColor="#3D8C5C"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/divider"
            app:layout_constraintStart_toStartOf="@id/editTxtID"
            android:layout_marginTop="36dp"/>

        <EditText
            android:id="@+id/editTxtID"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:hint="이메일을 입력하세요"
            android:inputType="textEmailAddress"
            android:textSize="14sp"
            android:padding="14dp"
            android:background="@drawable/edit_bg"
            app:layout_constraintTop_toBottomOf="@id/txtID"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginStart="32dp"
            android:layout_marginEnd="32dp"
            android:layout_marginTop="6dp"/>

        <!-- 비밀번호 -->
        <TextView
            android:id="@+id/txtPassword"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="비밀번호"
            android:textSize="12sp"
            android:textColor="#3D8C5C"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/editTxtID"
            app:layout_constraintStart_toStartOf="@id/editTxtPW"
            android:layout_marginTop="20dp"/>

        <EditText
            android:id="@+id/editTxtPW"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:hint="비밀번호를 입력하세요"
            android:inputType="textPassword"
            android:textSize="14sp"
            android:padding="14dp"
            android:background="@drawable/edit_bg"
            app:layout_constraintTop_toBottomOf="@id/txtPassword"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginStart="32dp"
            android:layout_marginEnd="32dp"
            android:layout_marginTop="6dp"/>

        <!-- reCAPTCHA v2 -->
        <Button
            android:id="@+id/btnCaptcha"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:text="보안 문자 인증하기"
            android:textSize="14sp"
            android:textColor="#3D8C5C"
            android:backgroundTint="#D2EFD8"
            app:layout_constraintTop_toBottomOf="@id/editTxtPW"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginStart="32dp"
            android:layout_marginEnd="32dp"
            android:layout_marginTop="20dp"/>

        <TextView
            android:id="@+id/txtCaptchaStatus"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="13sp"
            android:textColor="#2D7A4F"
            android:gravity="center"
            app:layout_constraintTop_toBottomOf="@id/btnCaptcha"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="6dp"/>

        <!-- 버튼 -->
        <Button
            android:id="@+id/btnLogin"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:text="로그인"
            android:textSize="15sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#66B375"
            app:layout_constraintTop_toBottomOf="@id/txtCaptchaStatus"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginStart="32dp"
            android:layout_marginEnd="32dp"
            android:layout_marginTop="28dp"/>

        <Button
            android:id="@+id/btnSignUp"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:text="회원가입"
            android:textSize="15sp"
            android:textColor="#3D8C5C"
            android:backgroundTint="#00000000"
            app:layout_constraintTop_toBottomOf="@id/btnLogin"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginStart="32dp"
            android:layout_marginEnd="32dp"
            android:layout_marginTop="4dp"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

</ScrollView>
