<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F7FCF9">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:paddingBottom="48dp">

        <!-- 뒤로가기 -->
        <Button
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:text="←"
            android:textSize="18sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#66B375"
            app:cornerRadius="24dp"
            android:padding="0dp"
            android:layout_marginTop="4dp"/>

        <!-- 헤더 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="PinKid"
            android:textSize="32sp"
            android:textStyle="bold"
            android:textColor="#2D7A4F"
            android:gravity="center"
            android:layout_marginTop="12dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="우리 아이가 있는 곳, 언제나 함께"
            android:textSize="14sp"
            android:textColor="#5AAB78"
            android:gravity="center"
            android:layout_marginTop="8dp"/>

        <View
            android:layout_width="48dp"
            android:layout_height="4dp"
            android:background="#66B375"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="36dp"/>

        <!-- ───── 위치 등록 섹션 ───── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="위치 등록하기"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#1A1A1A"
            android:layout_marginBottom="14dp"/>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#D2EFD8"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            android:layout_marginBottom="28dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- 주소 라벨 -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="주소"
                    android:textSize="12sp"
                    android:textColor="#3D8C5C"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp"/>

                <!-- 주소 선택 박스 -->
                <TextView
                    android:id="@+id/txtSelectedAddress"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="이곳을 터치하여 주소를 검색하세요"
                    android:background="@drawable/edit_bg"
                    android:textSize="14sp"
                    android:textColor="#888888"
                    android:padding="14dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:layout_marginBottom="20dp"/>

                <!-- 별명 라벨 -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="별명"
                    android:textSize="12sp"
                    android:textColor="#3D8C5C"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp"/>

                <!-- 별명 입력 -->
                <EditText
                    android:id="@+id/editNickname"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="예: 집, 학교, 학원"
                    android:textSize="14sp"
                    android:padding="14dp"
                    android:background="@drawable/edit_bg"
                    android:inputType="text"
                    android:layout_marginBottom="20dp"/>

                <!-- 등록 버튼 -->
                <Button
                    android:id="@+id/btnRegister"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="위치 등록하기"
                    android:textSize="15sp"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#66B375"/>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- ───── 등록된 위치 섹션 ───── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="등록된 위치"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#1A1A1A"
            android:layout_marginBottom="14dp"/>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#D2EFD8"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- 위치 목록 (동적) -->
                <LinearLayout
                    android:id="@+id/locationsContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"/>

                <!-- 빈 상태 메시지 -->
                <TextView
                    android:id="@+id/txtEmpty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="등록된 위치가 없습니다"
                    android:textSize="14sp"
                    android:textColor="#AAAAAA"
                    android:gravity="center"
                    android:padding="20dp"
                    android:visibility="gone"/>

                <!-- 수정 / 삭제 버튼 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="12dp">

                    <Button
                        android:id="@+id/btnEditNickname"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:text="별명 수정"
                        android:textSize="13sp"
                        android:textColor="#FFFFFF"
                        android:backgroundTint="#66B375"
                        android:layout_marginEnd="8dp"/>

                    <Button
                        android:id="@+id/btnDeleteLocation"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:text="위치 삭제"
                        android:textSize="13sp"
                        android:textColor="#FFFFFF"
                        android:backgroundTint="#EF9A9A"/>

                </LinearLayout>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

    </LinearLayout>

</ScrollView>
