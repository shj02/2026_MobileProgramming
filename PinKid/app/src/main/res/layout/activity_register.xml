<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F7FCF9">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="40dp">

        <!-- 헤더 -->
        <TextView
            android:id="@+id/txtPinKid"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PinKid"
            android:textSize="32sp"
            android:textStyle="bold"
            android:textColor="#2D7A4F"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="60dp"/>

        <TextView
            android:id="@+id/txtSubTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="우리 아이가 있는 곳, 언제나 함께"
            android:textSize="14sp"
            android:textColor="#5AAB78"
            app:layout_constraintTop_toBottomOf="@id/txtPinKid"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="8dp"/>

        <View
            android:id="@+id/divider"
            android:layout_width="48dp"
            android:layout_height="4dp"
            android:background="#66B375"
            app:layout_constraintTop_toBottomOf="@id/txtSubTitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="20dp"/>

        <!-- 이메일 -->
        <TextView
            android:id="@+id/txtCreateID"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="이메일"
            android:textSize="12sp"
            android:textColor="#3D8C5C"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/divider"
            app:layout_constraintStart_toStartOf="@id/editTxtCreateID"
            android:layout_marginTop="32dp"/>

        <EditText
            android:id="@+id/editTxtCreateID"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:hint="이메일을 입력하세요"
            android:inputType="textEmailAddress"
            android:textSize="14sp"
            android:padding="14dp"
            android:background="@drawable/edit_bg"
            app:layout_constraintTop_toBottomOf="@id/txtCreateID"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginStart="32dp"
            android:layout_marginEnd="32dp"
            android:layout_marginTop="6dp"/>

        <!-- 비밀번호 -->
        <TextView
            android:id="@+id/txtCreatePassword"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="비밀번호"
            android:textSize="12sp"
            android:textColor="#3D8C5C"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/editTxtCreateID"
            app:layout_constraintStart_toStartOf="@id/editTxtCreatePW"
            android:layout_marginTop="20dp"/>

        <EditText
            android:id="@+id/editTxtCreatePW"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:hint="비밀번호를 입력하세요"
            android:inputType="textPassword"
            android:textSize="14sp"
            android:padding="14dp"
            android:background="@drawable/edit_bg"
            app:layout_constraintTop_toBottomOf="@id/txtCreatePassword"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginStart="32dp"
            android:layout_marginEnd="32dp"
            android:layout_marginTop="6dp"/>

        <!-- 비밀번호 확인 -->
        <TextView
            android:id="@+id/txtChkPassword"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="비밀번호 확인"
            android:textSize="12sp"
            android:textColor="#3D8C5C"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/editTxtCreatePW"
            app:layout_constraintStart_toStartOf="@id/editTxtChkPW"
            android:layout_marginTop="20dp"/>

        <EditText
            android:id="@+id/editTxtChkPW"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:hint="비밀번호를 한번 더 입력하세요"
            android:inputType="textPassword"
            android:textSize="14sp"
            android:padding="14dp"
            android:background="@drawable/edit_bg"
            app:layout_constraintTop_toBottomOf="@id/txtChkPassword"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginStart="32dp"
            android:layout_marginEnd="32dp"
            android:layout_marginTop="6dp"/>

        <!-- 이름 -->
        <TextView
            android:id="@+id/txtName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="이름"
            android:textSize="12sp"
            android:textColor="#3D8C5C"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/editTxtChkPW"
            app:layout_constraintStart_toStartOf="@id/editTxtName"
            android:layout_marginTop="20dp"/>

        <EditText
            android:id="@+id/editTxtName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:hint="이름을 입력하세요"
            android:inputType="textPersonName"
            android:textSize="14sp"
            android:padding="14dp"
            android:background="@drawable/edit_bg"
            app:layout_constraintTop_toBottomOf="@id/txtName"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginStart="32dp"
            android:layout_marginEnd="32dp"
            android:layout_marginTop="6dp"/>

        <!-- 역할 선택 -->
        <TextView
            android:id="@+id/txtRoleLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="역할 선택"
            android:textSize="12sp"
            android:textColor="#3D8C5C"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/editTxtName"
            app:layout_constraintStart_toStartOf="@id/cardRole"
            android:layout_marginTop="20dp"/>

        <androidx.cardview.widget.CardView
            android:id="@+id/cardRole"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#D2EFD8"
            app:cardCornerRadius="10dp"
            app:cardElevation="2dp"
            app:layout_constraintTop_toBottomOf="@id/txtRoleLabel"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginStart="32dp"
            android:layout_marginEnd="32dp"
            android:layout_marginTop="6dp">

            <LinearLayout
                android:id="@+id/layoutRoleCheck"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp">

                <CheckBox
                    android:id="@+id/checkParent"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="학부모"
                    android:textSize="15sp"
                    android:textColor="#1A1A1A"
                    android:textStyle="bold"
                    android:buttonTint="#66B375"/>

                <CheckBox
                    android:id="@+id/checkChild"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="아이"
                    android:textSize="15sp"
                    android:textColor="#1A1A1A"
                    android:textStyle="bold"
                    android:buttonTint="#66B375"/>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- 버튼 -->
        <Button
            android:id="@+id/btnSignUp"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:text="회원가입"
            android:textSize="15sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#66B375"
            app:layout_constraintTop_toBottomOf="@id/cardRole"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginStart="32dp"
            android:layout_marginEnd="32dp"
            android:layout_marginTop="32dp"/>

        <Button
            android:id="@+id/btnGoLogin"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:text="로그인으로 돌아가기"
            android:textSize="15sp"
            android:textColor="#3D8C5C"
            android:backgroundTint="#00000000"
            app:layout_constraintTop_toBottomOf="@id/btnSignUp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginStart="32dp"
            android:layout_marginEnd="32dp"
            android:layout_marginTop="4dp"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

</ScrollView>
